    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "wrangler": "^4.84.1"
  },
  "devDependencies": {
    "@serwist/next": "^9.5.7",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.5.2",
    "serwist": "^9.5.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
